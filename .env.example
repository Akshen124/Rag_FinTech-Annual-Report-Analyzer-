# Copy this file to .env and fill in your secrets. Do NOT commit your .env file.
GROQ_API_KEY=your_groq_api_key_here
GROQ_EMBEDDINGS_URL=https://api.groq.ai/v1/embeddings
GROQ_EMBEDDING_MODEL=embed-small
GROQ_CHAT_URL=https://api.groq.ai/v1/chat/completions
GROQ_CHAT_MODEL=gpt-3o-mini
CHROMA_PERSIST_DIR=chroma_db
